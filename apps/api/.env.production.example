# =====================================================================
# trace-scope API — PRODUCTION environment template
# =====================================================================
# Copy this file to `.env` on the production host.
#
# All values below MUST be overridden for production:
#   - SESSION_SECRET (BUG-017: required, no fallback in production)
#   - COOKIE_SECURE (BUG-017: required true in production)
#   - MYSQL_* (real database credentials)
#   - STORAGE_DIR (real absolute path on the host)
#   - CORS_ORIGINS (real public domain)
#   - ADMIN_BOOTSTRAP_PASSWORD (rotate immediately after first login)
#
# Config will refuse to start in production if SESSION_SECRET is unset
# or if COOKIE_SECURE is not "true".
# =====================================================================

# ---------- Server ----------
# Bind address. 0.0.0.0 if behind a reverse proxy (Caddy/nginx).
HOST=0.0.0.0
PORT=4000

# ---------- MySQL ----------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=trace_scope
MYSQL_PASSWORD=replace-with-real-password
MYSQL_DATABASE=trace_scope_platform

# ---------- Storage ----------
# Absolute path on the production host. backup-mysql.ps1 and
# backup-uploads.ps1 both reference this variable.
STORAGE_DIR=/var/lib/trace-scope/storage
# UPLOAD_ROOT is a legacy alias — leave unset in fresh deployments.
# UPLOAD_ROOT=

# Upload size limit in bytes. 10 MiB = 10485760. (BUG-027: was missing.)
MAX_UPLOAD_BYTES=10485760

# ---------- Auth ----------
# REQUIRED: config.ts will throw at startup if this is unset in
# production. Generate with: openssl rand -base64 48
SESSION_SECRET=replace-with-48-byte-random-string-from-openssl-rand-base64-48

# REQUIRED: must be true in production. config.ts will throw at
# startup if unset or false under NODE_ENV=production (BUG-017).
COOKIE_SECURE=true

# Bootstrap admin — created on first boot only if no admin exists.
# Rotate ADMIN_BOOTSTRAP_PASSWORD immediately after first login.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-now

# ---------- Network ----------
PUBLIC_BASE_URL=https://trace.example.com
CORS_ORIGINS=https://trace.example.com
# production: trust the reverse proxy in front of Fastify (Caddy).
TRUST_PROXY=true

# ---------- Logging / limits ----------
LOG_LEVEL=info
BODY_LIMIT_BYTES=10485760
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000