# =====================================================================
# trace-scope API — DEV environment template
# =====================================================================
# Copy this file to `.env` for local development.
#
# Layout principle (BUG-028 fix):
#   - Every variable here matches the fallback value used by
#     apps/api/src/app/config.ts when the env var is unset. So copy
#     this file as-is and dev "just works".
#   - Production-only / dev-only variables are tagged inline.
#   - Legacy aliases (e.g. UPLOAD_ROOT) are kept for backward
#     compatibility but the canonical name is listed first.
#
# Order: server → mysql → storage → auth → network → limits
# =====================================================================

# ---------- Server ----------
# dev-only: Fastify bind address. Use 0.0.0.0 for container, 127.0.0.1 for local.
HOST=0.0.0.0
PORT=4000

# ---------- MySQL ----------
# dev-only fallback in config.ts: host=localhost, user=root, password='', database=trace-scope-platform
# Listed values below match a typical local dev MySQL 8 setup.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=trace_scope
MYSQL_PASSWORD=replace-me
MYSQL_DATABASE=trace_scope

# ---------- Storage ----------
# STORAGE_DIR is canonical (used by API, backup scripts, deployment docs).
# UPLOAD_ROOT is a legacy alias kept for backward compatibility — config.ts
# falls back from STORAGE_DIR → UPLOAD_ROOT → './storage'.
STORAGE_DIR=./data/storage
UPLOAD_ROOT=./data/uploads

# Upload size limit in bytes. 10 MiB = 10485760. (BUG-027: was missing.)
MAX_UPLOAD_BYTES=10485760

# ---------- Auth ----------
# dev-only: In production, BUG-017 enforces that SESSION_SECRET is
# explicitly set (no fallback) and that COOKIE_SECURE=true is explicit.
# Dev fallback in config.ts is the literal string
# 'dev-secret-change-in-production' — DO NOT ship this to production.
SESSION_SECRET=dev-secret-change-in-production
COOKIE_SECURE=false

# Bootstrap admin credentials. config.ts falls back to
# username=admin / password=admin123 in dev. For production,
# override both with strong values and rotate immediately after
# first login.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=admin123

# ---------- Network ----------
PUBLIC_BASE_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:5173,http://localhost:4000
# dev-only: config.ts default is true (for reverse-proxy prod setups).
# Set to false if running `npm run dev` without any reverse proxy
# in front of Fastify.
TRUST_PROXY=false

# ---------- Logging / limits ----------
LOG_LEVEL=info
BODY_LIMIT_BYTES=10485760
RATE_LIMIT_MAX=1000
RATE_LIMIT_WINDOW_MS=60000